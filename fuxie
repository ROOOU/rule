+proxy-groups:
  - name: 🧩 0.8倍率节点
    type: select
    include-all: true
    filter: (?i)0\.8

  - name: 🇭🇰 0.8香港节点
    type: select
    include-all: true
    filter: (?i)(?=.*0\.8)(?=.*(港|hk|hong kong|hongkong))

  - name: 🤖 AI分流
    type: select
    proxies:
      - 🧩 0.8倍率节点
      - 🇭🇰 0.8香港节点
      - 🚀 节点选择
      - ♻️ 自动选择
      - 🇸🇬 狮城节点
      - 🇭🇰 香港节点
      - 🇨🇳 台湾节点
      - 🇯🇵 日本节点
      - 🇺🇲 美国节点
      - 🇰🇷 韩国节点
      - 🚀 手动切换
      - DIRECT

